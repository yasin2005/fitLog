<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'History' }) %>
</head>
<body>
  <%- include('partials/nav', { active: 'history' }) %>

  <main class="page-content">
    <div class="page-header">
      <h1>This Week</h1>
      <p class="subtitle">Workouts you've logged in the past 7 days.</p>
    </div>

    <% if (logs.length === 0) { %>
      <div class="empty-state">
        <p>No workouts logged this week.</p>
        <a href="/workouts" class="btn btn-primary">Go to My Workouts</a>
      </div>
    <% } else { %>
      <div class="history-list">
        <% logs.forEach(function(log) { %>
          <div class="history-item">
            <div class="history-header">
              <span class="history-name"><%= log.workoutName %></span>
              <span class="history-date muted">
                <%= new Date(log.date).toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' }) %>
              </span>
            </div>
            <%# Guard against logs whose original workout was deleted (populate returns null) %>
            <% if (log.workoutId && log.workoutId.exercises) { %>
              <ul class="history-exercise-list">
                <% log.workoutId.exercises.forEach(function(exercise) { %>
                  <%# API names are lowercase — title-case for display %>
                  <li>
                    <span><%= toTitleCase(exercise.name) %></span>
                    <%# Fallback to defaults for logs recorded before sets/reps were added %>
                    <span class="history-exercise-volume"><%= exercise.sets || 3 %> sets &middot; <%= exercise.reps || 10 %> reps</span>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } %>
  </main>
</body>
</html>