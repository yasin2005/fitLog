<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Workouts – FitLog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <span class="brand-mark">◆</span>
      <span class="brand-name">FitLog</span>
    </div>
    <nav class="nav">
      <a href="/" class="nav-link">Search</a>
      <a href="/workouts" class="nav-link active">My Workouts</a>
      <a href="/history" class="nav-link">History</a>
    </nav>
  </header>

  <main class="page-content">
    <div class="page-header">
      <div>
        <h1>My Workouts</h1>
        <p class="subtitle">Saved routines you've built.</p>
      </div>
    </div>

    <% if (workouts.length === 0) { %>
      <div class="empty-state">
        <p>No workouts saved yet.</p>
        <a href="/" class="btn btn-primary">Go build one</a>
      </div>
    <% } else { %>
      <div class="workout-grid">
        <% workouts.forEach(function(w) { %>
          <div class="workout-card">
            <div class="workout-card-header">
              <h2 class="workout-card-name"><%= w.name %></h2>
              <div class="workout-card-actions">
                <a href="/?edit=<%= w._id %>" class="btn btn-sm">Edit</a>
                <form method="POST" action="/workouts/<%= w._id %>/delete" onsubmit="return confirm('Delete this workout? This cannot be undone.')">
                  <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
              </div>
            </div>

            <% if (w.description) { %>
              <p class="workout-card-desc"><%= w.description %></p>
            <% } %>

            <p class="muted"><%= w.exercises.length %> exercise<%= w.exercises.length !== 1 ? 's' : '' %></p>

            <ul class="workout-ex-list">
              <% w.exercises.forEach(function(ex) { %>
                <%# Clicking an exercise row opens the detail popup %>
                <%# Fall back to defaults for workouts saved before sets/reps were added %>
                <li class="workout-ex-item"
                    data-workout-id="<%= w._id %>"
                    data-exercise-id="<%= ex.exerciseId %>">
                  <span class="workout-ex-name"><%= ex.name.replace(/\b\w/g, function(c){ return c.toUpperCase(); }) %></span>
                  <span class="workout-ex-volume"><%= ex.sets || 3 %> sets &middot; <%= ex.reps || 10 %> reps</span>
                </li>
              <% }); %>
            </ul>

            <form method="POST" action="/history">
              <input type="hidden" name="workoutId" value="<%= w._id %>" />
              <button type="submit" class="btn btn-primary btn-block">Log this workout</button>
            </form>
          </div>
        <% }); %>
      </div>
    <% } %>
  </main>

  <!-- ── Exercise detail popup (same structure as main page, no Add button) ── -->
  <div class="popup-overlay hidden" id="exPopupOverlay">
    <div class="popup">
      <button class="popup-close" id="exPopupClose">✕</button>
      <div class="popup-content">
        <div class="popup-info">
          <h2 id="exPopupName"></h2>
          <div class="tags" id="exPopupTags"></div>

          <div class="popup-section" id="exPopupTargetSection">
            <h4>Target muscle</h4>
            <p id="exPopupTarget"></p>
          </div>

          <div class="popup-section" id="exPopupSecondarySection">
            <h4>Secondary muscles</h4>
            <p id="exPopupSecondary"></p>
          </div>

          <div class="popup-section">
            <h4>How to do it</h4>
            <ol id="exPopupInstructions"></ol>
          </div>
        </div>
        <div class="popup-gif">
          <img id="exPopupImg" src="" alt="" />
        </div>
      </div>
    </div>
  </div>


  <!-- Workout data for the JS — exercises are read via dataset in workouts.js -->
  <div id="workoutsData" data-workouts="<%= JSON.stringify(workouts) %>" hidden></div>
  <script src="/js/workouts.js"></script>
</body>
</html>
