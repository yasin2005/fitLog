<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Workouts' }) %>
</head>
<body>
  <%- include('partials/nav', { active: 'workouts' }) %>

  <main class="page-content">
    <div class="page-header">
      <div>
        <h1>My Workouts</h1>
        <p class="subtitle">Saved routines you've built.</p>
      </div>
    </div>

    <% if (workouts.length === 0) { %>
      <div class="empty-state">
        <p>No workouts saved yet.</p>
        <a href="/" class="btn btn-primary">Go build one</a>
      </div>
    <% } else { %>
      <div class="workout-grid">
        <% workouts.forEach(function(w) { %>
          <div class="workout-card">
            <div class="workout-card-header">
              <h2 class="workout-card-name"><%= w.name %></h2>
              <div class="workout-card-actions">
                <a href="/?edit=<%= w._id %>" class="btn btn-sm">Edit</a>
                <form method="POST" action="/workouts/<%= w._id %>/delete" onsubmit="return confirm('Delete this workout? This cannot be undone.')">
                  <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
              </div>
            </div>

            <% if (w.description) { %>
              <p class="workout-card-desc"><%= w.description %></p>
            <% } %>

            <p class="muted"><%= w.exercises.length %> exercise<%= w.exercises.length !== 1 ? 's' : '' %></p>

            <ul class="workout-ex-list">
              <% w.exercises.forEach(function(ex) { %>
                <%# Clicking an exercise row opens the detail popup %>
                <%# Fall back to defaults for workouts saved before sets/reps were added %>
                <li class="workout-ex-item"
                    data-workout-id="<%= w._id %>"
                    data-exercise-id="<%= ex.exerciseId %>">
                  <span class="workout-ex-name"><%= ex.name.replace(/\b\w/g, function(c){ return c.toUpperCase(); }) %></span>
                  <span class="workout-ex-volume"><%= ex.sets || 3 %> sets &middot; <%= ex.reps || 10 %> reps</span>
                </li>
              <% }); %>
            </ul>

            <form method="POST" action="/history">
              <input type="hidden" name="workoutId" value="<%= w._id %>" />
              <button type="submit" class="btn btn-primary btn-block">Log this workout</button>
            </form>
          </div>
        <% }); %>
      </div>
    <% } %>
  </main>

  <!-- Exercise detail popup -->
  <%- include('partials/popup', { prefix: 'exPopup', showAdd: false }) %>


  <!-- Workout data for the JS — exercises are read via dataset in workouts.js -->
  <div id="workoutsData" data-workouts="<%= JSON.stringify(workouts) %>" hidden></div>
  <script src="/js/workouts.js"></script>
</body>
</html>
