<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FitLog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="brand">
      <span class="brand-mark">◆</span>
      <span class="brand-name">FitLog</span>
    </div>
    <nav class="nav">
      <a href="/" class="nav-link active">Search</a>
      <a href="/workouts" class="nav-link">My Workouts</a>
      <a href="/history" class="nav-link">History</a>
    </nav>
  </header>

  <main class="layout">
    <!-- Left: search area -->
    <section class="main-col">
      <div class="hero">
        <h1>Find an exercise. Build a workout.</h1>
        <p class="subtitle">Search by name, muscle group, or equipment.</p>

        <form class="search" id="searchForm" autocomplete="off">
          <div class="search-input">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="7" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="text" id="searchQuery" placeholder="Try 'squat', 'biceps', or 'kettlebell'..." />
            <button type="button" id="clearSearchBtn" class="search-clear-btn" style="display:none" aria-label="Clear search">✕</button>
          </div>
          <button type="submit" class="btn btn-primary">Search</button>
        </form>

        <div class="filters">
          <!-- Muscle group dropdown -->
          <div class="filter-dropdown" id="bodyPartDropdown">
            <button type="button" class="filter-trigger" id="bodyPartTrigger">
              <span>Muscle group</span>
              <span class="filter-badge hidden" id="bodyPartBadge"></span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" class="filter-chevron"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="filter-panel hidden" id="bodyPartPanel">
              <div class="filter-options" id="bodyPartPills">
                <button type="button" class="filter-option filter-option-all" id="selectAllBodyParts">Select all</button>
                <div class="filter-option-divider"></div>
                <button type="button" class="filter-option" data-value="back">Back</button>
                <button type="button" class="filter-option" data-value="cardio">Cardio</button>
                <button type="button" class="filter-option" data-value="chest">Chest</button>
                <button type="button" class="filter-option" data-value="lower legs">Lower Legs</button>
                <button type="button" class="filter-option" data-value="neck">Neck</button>
                <button type="button" class="filter-option" data-value="shoulders">Shoulders</button>
                <button type="button" class="filter-option" data-value="upper arms">Upper Arms</button>
                <button type="button" class="filter-option" data-value="upper legs">Upper Legs</button>
                <button type="button" class="filter-option" data-value="waist">Waist</button>
              </div>
              <button type="button" class="filter-clear" id="clearBodyParts">Clear all</button>
            </div>
          </div>

          <!-- Equipment dropdown -->
          <div class="filter-dropdown" id="equipmentDropdown">
            <button type="button" class="filter-trigger" id="equipmentTrigger">
              <span>Equipment</span>
              <span class="filter-badge hidden" id="equipmentBadge"></span>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" class="filter-chevron"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="filter-panel hidden" id="equipmentPanel">
              <div class="filter-options" id="equipmentPills">
                <button type="button" class="filter-option filter-option-all" id="selectAllEquipments">Select all</button>
                <div class="filter-option-divider"></div>
                <button type="button" class="filter-option" data-value="assisted">Assisted</button>
                <button type="button" class="filter-option" data-value="band">Band</button>
                <button type="button" class="filter-option" data-value="barbell">Barbell</button>
                <button type="button" class="filter-option" data-value="body weight">Body Weight</button>
                <button type="button" class="filter-option" data-value="cable">Cable</button>
                <button type="button" class="filter-option" data-value="dumbbell">Dumbbell</button>
                <button type="button" class="filter-option" data-value="leverage machine">Leverage Machine</button>
                <button type="button" class="filter-option" data-value="resistance band">Resistance Band</button>
                <button type="button" class="filter-option" data-value="smith machine">Smith Machine</button>
                <button type="button" class="filter-option" data-value="weighted">Weighted</button>
              </div>
              <button type="button" class="filter-clear" id="clearEquipments">Clear all</button>
            </div>
          </div>
        </div>
      </div>

      <div class="results-header">
        <h2>Results</h2>
        <span class="muted" id="resultsCount">Search to get started</span>
      </div>

      <div class="results-grid" id="resultsGrid"></div>
    </section>

    <!-- Right: workout creator sidebar -->
    <aside class="side-col">

      <!-- Idle state: just the create button -->
      <div id="sidebarIdle" class="sidebar-panel">
        <p class="sidebar-tagline">Build a workout from your search results.</p>
        <button class="btn btn-primary btn-block" id="startCreateBtn">+ Create Workout</button>
      </div>

      <!-- Creating state: form + exercise list (hidden until button clicked) -->
      <div id="sidebarCreating" class="sidebar-panel hidden">
        <h2 class="sidebar-title">New Workout</h2>

        <label class="sidebar-label">
          Name
          <input type="text" id="workoutName" class="sidebar-input" placeholder="e.g. Push Day" />
        </label>

        <label class="sidebar-label">
          Description <span class="muted">(optional)</span>
          <textarea id="workoutDesc" class="sidebar-input sidebar-textarea" placeholder="Notes about this workout…"></textarea>
        </label>

        <h3 class="sidebar-section-title">Exercises <span class="muted" id="exCount">(0)</span></h3>
        <ul class="sidebar-ex-list" id="sidebarExList">
          <li class="sidebar-ex-empty">Search for exercises and click Add.</li>
        </ul>

        <div class="sidebar-actions">
          <button class="btn btn-primary btn-block" id="saveWorkoutBtn">Save Workout</button>
          <button class="btn btn-block" id="cancelCreateBtn">Cancel</button>
        </div>
      </div>

    </aside>
  </main>

  <!-- Exercise detail modal -->
  <div class="modal-overlay hidden" id="modalOverlay">
    <div class="modal">
      <button class="modal-close" id="modalClose">✕</button>
      <div class="modal-content">
        <div class="modal-info">
          <h2 id="modalName"></h2>
          <div class="tags" id="modalTags"></div>

          <div class="modal-section" id="modalTargetSection">
            <h4>Target muscle</h4>
            <p id="modalTarget"></p>
          </div>

          <div class="modal-section" id="modalSecondarySection">
            <h4>Secondary muscles</h4>
            <p id="modalSecondary"></p>
          </div>

          <div class="modal-section">
            <h4>How to do it</h4>
            <ol id="modalInstructions"></ol>
          </div>

          <!-- Add to workout button — only visible while creating a workout -->
          <div class="modal-section" id="modalAddSection" style="display:none">
            <button class="btn btn-primary" id="modalAddBtn">+ Add to Workout</button>
          </div>
        </div>
        <div class="modal-gif">
          <img id="modalImg" src="" alt="" />
        </div>
      </div>
    </div>
  </div>

  <script src="/js/index.js"></script>
</body>
</html>
